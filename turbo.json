{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        "build/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": [
        "^lint"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^test"
      ],
      "outputs": []
    },
    "prisma:generate": {
      "dependsOn": [
        "^prisma:generate"
      ],
      "outputs": [
        "node_modules/.prisma/**"
      ]
    },
    "prisma:migrate": {
      "cache": false
    }
  }
}
