generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Role {
  id   Int    @id @default(autoincrement()) @map("id_rol")
  name String @map("nombre_rol") @db.VarChar(30)

  users User[]

  @@map("rol")
}

model User {
  id           Int      @id @default(autoincrement()) @map("id_usuario")
  username     String   @db.VarChar(150)
  email        String?  @db.VarChar(100)
  passwordHash String?  @map("hash_contrasena") @db.VarChar(255)
  fullName     String   @map("nombre_completo") @db.VarChar(250)
  roleId       Int?     @map("id_rol")
  phone        String?  @map("telefono") @db.VarChar(20)
  address      String?  @map("direccion") @db.VarChar(50)
  activeState  Boolean? @default(true) @map("estado_activo")
  createdAt    DateTime @default(now()) @map("creado_en")
  updatedAt    DateTime @updatedAt @map("actualizado_en")

  role  Role?  @relation(fields: [roleId], references: [id])
  sales Sale[]

  @@map("usuario")
}

enum DeliveryState {
  PENDIENTE  @map("pendiente")
  CONFIRMADO @map("confirmado")
  EN_PROCESO @map("en proceso")
  EN_CAMINO  @map("en camino")
  FINALIZADO @map("finalizado")
  CANCELADO  @map("cancelado")

  @@map("delivery_state")
}

model Sale {
  id            Int            @id @default(autoincrement()) @map("id_venta")
  userId        Int            @map("id_usuario")
  address       String?        @map("direccion") @db.VarChar(150)
  deliveryState DeliveryState? @map("estado_entrega")
  totalPrice    Decimal        @map("precio_total") @db.Decimal(10, 2)
  canceledAt    DateTime?      @map("cancelado_en")
  createdAt     DateTime       @default(now()) @map("creado_en")
  updatedAt     DateTime       @updatedAt @map("actualizado_en")

  user  User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  items SaleItem[]

  @@map("venta")
}

model Category {
  id   Int    @id @default(autoincrement()) @map("id_categoria")
  name String @map("nombre_categoria") @db.VarChar(150)

  products Product[]

  @@map("categoria")
}

model Supplier {
  id          Int      @id @default(autoincrement()) @map("id_proveedor")
  name        String   @map("nombre_proveedor") @db.VarChar(150)
  cuil        String?  @db.VarChar(50)
  email       String?  @map("correo") @db.VarChar(50)
  phoneNumber String?  @map("numero_telefono") @db.VarChar(50)
  activeState Boolean  @default(true) @map("estado_activo")
  createdAt   DateTime @default(now()) @map("creado_en")
  updatedAt   DateTime @updatedAt @map("actualizado_en")

  products Product[]

  @@map("proveedor")
}

model Product {
  id          Int      @id @default(autoincrement()) @map("id_producto")
  name        String   @map("nombre_producto") @db.VarChar(255)
  description String?  @map("descripcion_producto") @db.Text
  imagePath   String?  @map("ruta_imagen") @db.VarChar(500)
  price       Decimal  @map("precio") @db.Decimal(10, 2)
  categoryId  Int      @map("id_categoria")
  supplierId  Int?     @map("id_proveedor")
  activeState Boolean  @default(true) @map("estado_activo")
  stock       Int      @map("stock")
  createdAt   DateTime @default(now()) @map("creado_en")
  updatedAt   DateTime @updatedAt @map("actualizado_en")

  category  Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  supplier  Supplier?  @relation(fields: [supplierId], references: [id])
  saleItems SaleItem[]

  @@map("producto")
}

model SaleItem {
  id        Int      @id @default(autoincrement()) @map("id_detalle_venta")
  saleId    Int      @map("id_venta")
  productId Int      @map("id_producto")
  amount    Int      @default(1) @map("cantidad")
  price     Decimal  @map("precio") @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("creado_en")
  updatedAt DateTime @updatedAt @map("actualizado_en")

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("detalle_venta")
}
